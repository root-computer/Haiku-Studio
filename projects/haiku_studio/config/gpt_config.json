{
  "paths": {
    "data_dir": "data",
    "tokenizer_path": "data/tokenizer.json",
    "corpus_dir": "projects/haiku_studio/datasets/corpus",
    "pretokenized_cache_dir": "projects/haiku_studio/cache/pretokenized",
    "pretrain_checkpoint": "projects/haiku_studio/checkpoints/model.pt",
    "pretrain_best_checkpoint": "projects/haiku_studio/checkpoints/model.best.pt",
    "pretrain_log": "projects/haiku_studio/logs/pretrain_loss.jsonl",
    "sft_dataset": "projects/haiku_studio/datasets/sft",
    "sft_cache": "projects/haiku_studio/cache/sft_cache.pt",
    "sft_checkpoint": "projects/haiku_studio/checkpoints/model.sft.pt",
    "sft_best_checkpoint": "projects/haiku_studio/checkpoints/model.sft.best.pt",
    "sft_log": "projects/haiku_studio/logs/sft_loss.jsonl",
    "dpo_dataset": "projects/haiku_studio/datasets/dpo",
    "dpo_cache": "projects/haiku_studio/cache/dpo_cache.pt",
    "dpo_checkpoint": "projects/haiku_studio/checkpoints/model.dpo.pt",
    "dpo_best_checkpoint": "projects/haiku_studio/checkpoints/model.dpo.best.pt",
    "dpo_log": "projects/haiku_studio/logs/dpo_loss.jsonl"
  },
  "model": {
    "block_size": 1024,
    "n_layer": 26,
    "n_head": 8,
    "n_kv_head": 8,
    "n_embd": 1024,
    "dropout": 0.0,
    "rope_base": 50000.0,
    "grad_checkpoint": true,
    "hidden_mult": 2.67,
    "tied_embeddings": false,
    "residual_init_scale": true
  },
  "runtime": {
    "device": "auto",
    "seed": 1337,
    "use_amp": true,
    "allow_tf32": false,
    "cudnn_benchmark": true,
    "enable_flash_sdp": true,
    "enable_mem_efficient_sdp": true,
    "enable_math_sdp": true
  },
  "data": {
    "force_rebuild_cache": false,
    "hash_corpus_files": false,
    "val_ratio": 0.02,
    "max_val_tokens": 200000,
    "max_doc_chars": 1000000,
    "shuffle_buffer_docs": 256,
    "shuffle_buffer_tokens": 500000,
    "chunk_tokens": 250000,
    "stride": 1024,
    "eot_marker": "<eot>"
  },
  "train": {
    "epochs": 2,
    "max_steps": null,
    "batch_size": 1,
    "grad_accum": 8,
    "logit_chunk_size": 64
  },
  "optimizer": {
    "lr": 0.0003,
    "lr_min": 1e-05,
    "beta1": 0.9,
    "beta2": 0.95,
    "eps": 1e-08,
    "weight_decay": 0.01,
    "max_grad_norm": 1.0,
    "foreach": false
  },
  "scheduler": {
    "type": "cosine",
    "warmup_pct": 0.02
  },
  "logging": {
    "log_every": 50,
    "eval_every": 500,
    "save_every": 1000,
    "val_batches": 200
  },
  "sft": {
    "base_checkpoint": "projects/haiku_studio/checkpoints/model.best.pt",
    "epochs": 2,
    "max_steps": null,
    "batch_size": 1,
    "grad_accum": 8,
    "lr": 5e-05,
    "lr_min": 5e-06,
    "warmup_pct": 0.03,
    "weight_decay": 0.0,
    "val_ratio": 0.05,
    "shuffle": true,
    "min_supervised_tokens": 1,
    "force_rebuild_cache": false,
    "log_every": 25,
    "eval_every": 100,
    "save_every": 500,
    "val_batches": 100
  },
  "dpo": {
    "policy_checkpoint": "projects/haiku_studio/checkpoints/model.sft.best.pt",
    "reference_checkpoint": "projects/haiku_studio/checkpoints/model.sft.reference.pt",
    "create_reference_if_missing": true,
    "epochs": 1,
    "max_steps": null,
    "batch_size": 1,
    "grad_accum": 8,
    "lr": 3e-06,
    "lr_min": 3e-07,
    "beta": 0.1,
    "warmup_pct": 0.03,
    "weight_decay": 0.0,
    "val_ratio": 0.05,
    "shuffle": true,
    "force_rebuild_cache": false,
    "log_every": 25,
    "eval_every": 100,
    "save_every": 250,
    "val_batches": 100,
    "logit_chunk_size": 64
  },
  "project": {
    "name": "haiku_studio",
    "root": "projects/haiku_studio",
    "tokenizer_path": "projects/haiku_studio/tokenizer.json",
    "config_path": "projects/haiku_studio/config/gpt_config.json"
  }
}